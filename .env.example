# No API keys required for Quick scan!
# spotify-audit scrapes public Spotify embed endpoints directly.

# Anthropic API key (only needed for Deep tier)
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Standard tier API keys (all free) ---

# Genius: songwriter/producer credit lookups
# Get yours at https://genius.com/api-clients
GENIUS_TOKEN=

# Discogs: physical release verification (vinyl, CD, cassette)
# Get yours at https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# Setlist.fm: live concert history
# Get yours at https://api.setlist.fm/docs/1.0/ui/index.html
SETLISTFM_API_KEY=

# Bandsintown: touring / live show data
# Register at https://www.artists.bandsintown.com/support/api-installation
BANDSINTOWN_APP_ID=
